{
  "openapi": "3.0.3",
  "info": {
    "title": "WhalesBot 设备 HTTP API",
    "version": "1.0.0",
    "description": "manager-api 面向设备的匿名 HTTP 接口（无需登录）。签名算法与字段说明见文档「设备绑定」章节。\n\n响应体 `Result`：`code` 为 0 表示成功，其它为业务/错误码；`msg` 为提示信息；`data` 为载荷。\n\nOTA 接口返回 JSON 字符串主体（非 `Result` 包装），失败时 `error` 字段非空。"
  },
  "tags": [
    {
      "name": "device",
      "description": "设备密钥与激活",
      "x-group": "设备"
    },
    {
      "name": "ota",
      "description": "OTA 与连接参数",
      "x-group": "OTA"
    }
  ],
  "servers": [
    {
      "url": "https://your-manager-api-host",
      "description": "替换为实际部署的 manager-api 根地址（如有网关请在路径前加网关前缀）。"
    }
  ],
  "paths": {
    "/device/secret": {
      "post": {
        "tags": ["device"],
        "summary": "设备密钥下发",
        "description": "工厂侧使用 ProductSecret（智控台「应用 Secret」）对 `productId+deviceId+nonce` 做 HMAC-SHA256，下发 `deviceSecret`、`factoryToken`、`websocketUrl` 等。",
        "operationId": "issueDeviceSecret",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DeviceSecretReqDTO"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultDeviceSecretRespDTO"
                }
              }
            }
          }
        }
      }
    },
    "/device/activate": {
      "post": {
        "tags": ["device"],
        "summary": "激活 / 绑定设备",
        "description": "设备侧使用 DeviceSecret 对 `productId+deviceId+nonce+timestamp` 拼接串做 HMAC-SHA256。强制绑定类应用需传 `userUuid`。",
        "operationId": "activateDevice",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DeviceBindSignReqDTO"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功，`data` 为提示文案（如「设备绑定成功」）",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultString"
                }
              }
            }
          }
        }
      }
    },
    "/ota/": {
      "post": {
        "tags": ["ota"],
        "summary": "OTA 检测与连接参数",
        "description": "设备上报固件与硬件信息；服务端校验签名后返回 WebSocket/MQTT、可选升级包等。响应体为 **DeviceReportRespDTO** 的 JSON（非 Result 包装）。",
        "operationId": "checkOta",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DeviceReportReqDTO"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功或业务错误（通过 body 内 `error` 字段区分）",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeviceReportRespDTO"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ResultDeviceSecretRespDTO": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "description": "0 成功"
          },
          "msg": {
            "type": "string"
          },
          "data": {
            "$ref": "#/components/schemas/DeviceSecretRespDTO"
          }
        }
      },
      "ResultString": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer"
          },
          "msg": {
            "type": "string"
          },
          "data": {
            "type": "string",
            "description": "如「设备绑定成功」「设备已激活」"
          }
        }
      },
      "DeviceSecretReqDTO": {
        "type": "object",
        "required": [
          "productId",
          "deviceId",
          "mac",
          "nonce",
          "timestamp",
          "factorySign"
        ],
        "properties": {
          "productId": {
            "type": "string",
            "description": "产品 ID"
          },
          "deviceId": {
            "type": "string",
            "description": "设备 ID"
          },
          "mac": {
            "type": "string",
            "description": "MAC 地址"
          },
          "nonce": {
            "type": "string",
            "description": "防重放随机串"
          },
          "timestamp": {
            "type": "integer",
            "format": "int64",
            "description": "请求时间戳（秒或毫秒，与服务端约定一致）"
          },
          "factorySign": {
            "type": "string",
            "description": "HMAC-SHA256，密钥为 ProductSecret 的 UTF-8 字节，载荷为 productId+deviceId+nonce；Hex64 或 Base64"
          }
        }
      },
      "DeviceBindSignReqDTO": {
        "type": "object",
        "required": [
          "productId",
          "deviceId",
          "nonce",
          "timestamp",
          "signature"
        ],
        "properties": {
          "productId": {
            "type": "string"
          },
          "deviceId": {
            "type": "string"
          },
          "nonce": {
            "type": "string"
          },
          "timestamp": {
            "type": "integer",
            "format": "int64"
          },
          "signature": {
            "type": "string",
            "description": "HMAC_SHA256(DeviceSecret, productId+deviceId+nonce+timestamp)"
          },
          "userUuid": {
            "type": "string",
            "description": "强制绑定应用必填，与智控台用户一致"
          }
        }
      },
      "DeviceSecretRespDTO": {
        "type": "object",
        "properties": {
          "productId": {
            "type": "string"
          },
          "deviceId": {
            "type": "string"
          },
          "deviceSecret": {
            "type": "string",
            "description": "设备密钥（32 字节随机 Hex，小写）"
          },
          "factoryToken": {
            "type": "string",
            "description": "工厂临时通讯 token（约 48 小时有效）"
          },
          "websocketUrl": {
            "type": "string",
            "description": "连接 whalesbotai-server 的 WebSocket 地址"
          },
          "factoryTokenExpireAt": {
            "type": "integer",
            "format": "int64",
            "description": "factoryToken 过期时间（毫秒时间戳）"
          }
        }
      },
      "DeviceReportReqDTO": {
        "type": "object",
        "required": [
          "productId",
          "deviceId",
          "nonce",
          "timestamp",
          "signature"
        ],
        "properties": {
          "productId": {
            "type": "string"
          },
          "deviceId": {
            "type": "string"
          },
          "nonce": {
            "type": "string"
          },
          "timestamp": {
            "type": "integer",
            "format": "int64"
          },
          "signature": {
            "type": "string"
          },
          "version": {
            "type": "integer",
            "description": "板级固件版本号"
          },
          "flash_size": {
            "type": "integer"
          },
          "minimum_free_heap_size": {
            "type": "integer"
          },
          "mac_address": {
            "type": "string"
          },
          "uuid": {
            "type": "string"
          },
          "chip_model_name": {
            "type": "string"
          },
          "chip_info": {
            "$ref": "#/components/schemas/ChipInfo"
          },
          "application": {
            "$ref": "#/components/schemas/Application"
          },
          "partition_table": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Partition"
            }
          },
          "ota": {
            "$ref": "#/components/schemas/OtaInfo"
          },
          "board": {
            "$ref": "#/components/schemas/BoardInfo"
          },
          "firmwares": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FirmwareInfo"
            }
          }
        }
      },
      "FirmwareInfo": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "version": {
            "type": "string"
          }
        }
      },
      "ChipInfo": {
        "type": "object",
        "properties": {
          "model": {
            "type": "integer"
          },
          "cores": {
            "type": "integer"
          },
          "revision": {
            "type": "integer"
          },
          "features": {
            "type": "integer"
          }
        }
      },
      "Application": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "compile_time": {
            "type": "string"
          },
          "idf_version": {
            "type": "string"
          },
          "elf_sha256": {
            "type": "string"
          }
        }
      },
      "Partition": {
        "type": "object",
        "properties": {
          "label": {
            "type": "string"
          },
          "type": {
            "type": "integer"
          },
          "subtype": {
            "type": "integer"
          },
          "address": {
            "type": "integer"
          },
          "size": {
            "type": "integer"
          }
        }
      },
      "OtaInfo": {
        "type": "object",
        "properties": {
          "label": {
            "type": "string"
          }
        }
      },
      "BoardInfo": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "ssid": {
            "type": "string"
          },
          "rssi": {
            "type": "integer"
          },
          "channel": {
            "type": "integer"
          },
          "ip": {
            "type": "string"
          },
          "mac": {
            "type": "string"
          }
        }
      },
      "DeviceReportRespDTO": {
        "type": "object",
        "description": "OTA 接口 JSON 体；失败时常仅含 `error`",
        "properties": {
          "server_time": {
            "$ref": "#/components/schemas/ServerTime"
          },
          "activation": {
            "$ref": "#/components/schemas/Activation"
          },
          "error": {
            "type": "string",
            "description": "错误说明；存在时通常为失败响应"
          },
          "firmwares": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Firmware"
            }
          },
          "websocket": {
            "$ref": "#/components/schemas/Websocket"
          },
          "mqtt": {
            "$ref": "#/components/schemas/MQTT"
          },
          "iotToken": {
            "type": "string"
          }
        }
      },
      "ServerTime": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "integer",
            "format": "int64"
          },
          "timeZone": {
            "type": "string"
          },
          "timezone_offset": {
            "type": "integer",
            "description": "时区偏移（分钟）"
          }
        }
      },
      "Activation": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "challenge": {
            "type": "string"
          }
        }
      },
      "Firmware": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "url": {
            "type": "string"
          }
        }
      },
      "Websocket": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          },
          "token": {
            "type": "string"
          }
        }
      },
      "MQTT": {
        "type": "object",
        "properties": {
          "endpoint": {
            "type": "string"
          },
          "clientId": {
            "type": "string"
          },
          "username": {
            "type": "string"
          },
          "password": {
            "type": "string"
          },
          "publish_topic": {
            "type": "string"
          },
          "subscribe_topic": {
            "type": "string"
          }
        }
      }
    }
  }
}
